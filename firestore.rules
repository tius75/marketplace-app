rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========
    function isSuperAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ========== PRODUCTS ==========
    match /products/{productId} {
      // Allow read untuk semua
      allow read: if true;
      
      // Create: user harus login DAN ownerId HARUS sama dengan user yang login
      allow create: if request.auth != null
                       && request.resource.data.ownerId == request.auth.uid;
      
      // Update: hanya owner atau superadmin
      allow update: if request.auth != null
                       && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
      
      // Delete: hanya owner atau superadmin
      allow delete: if request.auth != null
                       && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }

    // ========== USERS ==========
    match /users/{userId} {
      // Allow read untuk semua user yang login
      allow read: if request.auth != null;
      // Allow write hanya untuk user itu sendiri
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ========== USER ROLES ==========
    match /userRoles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ========== CATEGORIES ==========
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // ========== HOME ICONS ==========
    match /homeIcons/{iconId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // ========== ORDERS ==========
    match /orders/{orderId} {
      // User bisa baca semua orders
      allow read: if request.auth != null;
      
      // User bisa buat order
      allow create: if request.auth != null;
      
      // Update: hanya customer yang buat, admin, atau superadmin
      allow update: if request.auth != null && (
        resource.data.customerId == request.auth.uid || 
        isSuperAdmin() || 
        isAdmin()
      );
      
      // Delete: hanya superadmin
      allow delete: if isSuperAdmin();
    }

    // ========== SUPERADMINS ==========
    match /superadmins/{adminId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Tidak boleh diubah dari client
    }

    // ========== ADMINS ==========
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if false; // Tidak boleh diubah dari client
    }

    // ========== BANNERS ==========
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // ========== PROMOS ==========
    match /promos/{promoId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // ========== FEED ==========
    match /feed/{feedId} {
      allow read: if true;
      allow create: if request.auth != null
                       && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if request.auth != null
                              && resource.data.authorUid == request.auth.uid;
    }

    // ========== CHATS - MAIN COLLECTION ==========
    match /chats/{chatId} {
      // Baca chat - harus jadi participant
      allow read: if request.auth != null &&
                     request.auth.uid in resource.data.participants;

      // Buat chat baru - user harus ada di participants
      allow create: if request.auth != null &&
                       request.auth.uid in request.resource.data.participants;

      // Update chat (untuk last message) - harus jadi participant
      allow update: if request.auth != null &&
                       request.auth.uid in resource.data.participants;

      // Hapus chat - hanya superadmin
      allow delete: if isSuperAdmin();

      // ========== CHAT MESSAGES ==========
      match /messages/{messageId} {
        // Baca pesan - harus login
        allow read: if request.auth != null;

        // Buat pesan - harus login
        allow create: if request.auth != null
                         && request.resource.data.senderId == request.auth.uid;

        // Update pesan (hanya untuk mark as read)
        allow update: if request.auth != null;

        // Hapus pesan - hanya superadmin
        allow delete: if isSuperAdmin();
      }
    }

    // ========== GROUPS ==========
    match /groups/{groupId} {
      // Read: harus jadi member
      allow read: if request.auth != null &&
                     request.auth.uid in resource.data.members;

      // Create: harus login
      allow create: if request.auth != null;

      // Update: harus jadi member
      allow update: if request.auth != null &&
                       request.auth.uid in resource.data.members;

      // Delete: hanya superadmin
      allow delete: if isSuperAdmin();

      // Group messages
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if isSuperAdmin();
      }
    }

    // ========== NOTIFICATIONS ==========
    match /notifications/{notificationId} {
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                              && resource.data.userId == request.auth.uid;
    }
  }
}
