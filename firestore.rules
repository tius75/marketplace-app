rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // ========== PRODUCTS ==========
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || isSuperAdmin()
      );
    }

    // ========== USERS ==========
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // ========== CATEGORIES ==========
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ========== HOME ICONS ==========
    match /homeIcons/{iconId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ========== ORDERS ==========
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // ========== SUPERADMINS ==========
    match /superadmins/{adminId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ========== ADMINS ==========
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ========== BANNERS ==========
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ========== PROMOS ==========
    match /promos/{promoId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ========== FEED ==========
    match /feed/{feedId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ========== CHATS ==========
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSuperAdmin();
      }
    }

    // ========== GROUPS ==========
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSuperAdmin();
      }
    }

    // ========== NOTIFICATIONS ==========
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }
  }
}
